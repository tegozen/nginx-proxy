# OpenClaw: страница токенов по сессиям (сервис openclaw-usage-web, внутренний порт 3099).
# Скопируйте в openclaw.vhost (или другое имя .vhost) и перезапустите nginx.
#
# Домен (пример): openclaw.tegozen.ru — задайте SERVER_NAME или SUBDOMAIN+BASE_DOMAIN.
#
# Nginx в Docker → бэкенд по Docker-сети:
#   docker network connect <сеть_вашего_nginx_compose> openclaw-usage-web
#   UPSTREAM_HOST=openclaw-usage-web (как ниже).
# OpenClaw по умолчанию публикует :3099 на 0.0.0.0 — возможен доступ по http://IP:3099.
# Только домен / без IP:3099 с WAN: OPENCLAW_USAGE_WEB_BIND=127.0.0.1 в .env OpenClaw.
# С интернета: OPENCLAW_USAGE_WEB_TOKEN.

SERVER_NAME=openclaw.example.org
PORT=3099
UPSTREAM_HOST=openclaw-usage-web
